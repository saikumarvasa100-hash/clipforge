# =============================================================
# ClipForge -- Self-Hosted Configuration (.env.local)
# Zero paid APIs. Zero cloud dependencies. 100% local.
# =============================================================

# ── HERMES AI Agent (OpenRouter FREE models, $0 cost) ─────────
HERMES_URL=http://localhost:7890/v1
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Free models: nemotron (fast ~3s), qwen3.6-plus (reasoning), gpt-oss-20b (coding)

# ── Database (local SQLite) ───────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./clipforge.db

# ── Redis (Celery broker, local) ──────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Local File Storage ────────────────────────────────────────
STORAGE_DIR=/home/saiku/clipforge/storage

# ── Local Whisper (faster-whisper, no API cost) ───────────────
WHISPER_MODEL=base
# Options: tiny(39MB), base(142MB), small(466MB), medium(1.5GB), large-v3(3GB)
WHISPER_COMPUTE=float16

# ── Frontend URL ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Admin Auth (simple, no Supabase) ─────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# ── Browser Publishing (cookie files for TikTok/IG/FB/LinkedIn)
TIKTOK_COOKIES_FILE=/home/saiku/cookies/tiktok.json
INSTAGRAM_COOKIES_FILE=/home/saiku/cookies/instagram.json
FACEBOOK_COOKIES_FILE=/home/saiku/cookies/facebook.json
LINKEDIN_COOKIES_FILE=/home/saiku/cookies/linkedin.json

# ── PubSubHubbub (YouTube notifications, no API key needed) ───
PUBSUBHUBBUB_CALLBACK_URL=https://your-domain.com
