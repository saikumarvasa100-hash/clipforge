# ===========================
# DATABASE
# ===========================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/clipforge

# ===========================
# SUPABASE
# ===========================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_JWT_SECRET=your_jwt_secret_from_supabase_dashboard

# ===========================
# OPENAI
# ===========================
OPENAI_API_KEY=sk-proj-your_openai_api_key

# ===========================
# YOUTUBE
# ===========================
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# ===========================
# REDIS
# ===========================
REDIS_URL=redis://redis:6379/0

# ===========================
# TIKTOK
# ===========================
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# ===========================
# STRIPE
# ===========================
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret

# ===========================
# PUBSUBHUBBUB
# ===========================
PUBSUBHUBBUB_CALLBACK_URL=https://your-domain.com/api/webhooks/youtube

# ===========================
# CLOUDFLARE R2
# ===========================
CLOUDFLARE_R2_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=clipforge-clips
CLOUDFLARE_R2_PUBLIC_URL=https://your-r2-public-domain.com

# ===========================
# FRONTEND
# ===========================
FRONTEND_URL=http://localhost:3000
